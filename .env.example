# ==========================================
# UC TeamSpace 환경변수 설정 예시
# 실제 사용 시 .env 파일로 복사 후 값 변경
# ==========================================

# ── 데이터베이스 (PostgreSQL 16) ──────────
DATABASE_URL=postgresql://dev:dev1234@localhost:15432/uc_teamspace

# ── Redis ────────────────────────────────
REDIS_URL=redis://localhost:16379

# ── JWT 설정 ─────────────────────────────
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-refresh-secret-key-change-this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── 서버 설정 ────────────────────────────
NODE_ENV=development
PORT=3000
BACKEND_PORT=3000
FRONTEND_PORT=5173

# ── E2E 테스트 환경 (선택) ────────────────
E2E_BASE_URL=http://localhost:5173
E2E_MEMBER_EMAIL=nahyeongyu@example.com
E2E_MEMBER_PASSWORD=Test1234!
E2E_PART_LEADER_EMAIL=moonseunghong@example.com
E2E_PART_LEADER_PASSWORD=Test1234!
E2E_LEADER_EMAIL=jungwoochul@example.com
E2E_LEADER_PASSWORD=Test1234!

# ── 운영 환경 추가 설정 (docker-compose.prod.yml 사용 시) ──
# POSTGRES_DB=uc_teamspace
# POSTGRES_USER=prod
# POSTGRES_PASSWORD=your-strong-production-password
# REGISTRY_URL=ghcr.io
# DEPLOY_HOST=your-server-ip
