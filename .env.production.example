# PostgreSQL
POSTGRES_DB=weekly_report
POSTGRES_USER=prod
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# JWT
JWT_SECRET=CHANGE_ME_random_secret_key
JWT_REFRESH_SECRET=CHANGE_ME_another_random_secret_key

# CORS (leave empty or omit — Nginx proxies on the same origin in production)
# CORS_ORIGIN=https://your-domain.com
