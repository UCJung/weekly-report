generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────── 조직 ────────────

model Team {
  id            String     @id @default(cuid())
  name          String     @unique
  description   String?
  teamStatus    TeamStatus @default(PENDING)
  requestedById String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  requestedBy      Member?           @relation("TeamRequester", fields: [requestedById], references: [id])
  parts            Part[]
  teamProjects     TeamProject[]
  partSummaries    PartSummary[]
  teamMemberships  TeamMembership[]
  teamJoinRequests TeamJoinRequest[]

  @@map("teams")
}

model Part {
  id        String @id @default(cuid())
  name      String
  teamId    String
  sortOrder Int    @default(0)

  team            Team             @relation(fields: [teamId], references: [id])
  members         Member[]
  partSummaries   PartSummary[]
  teamMemberships TeamMembership[]

  @@unique([teamId, name])
  @@map("parts")
}

model Member {
  id                 String        @id @default(cuid())
  name               String
  email              String        @unique
  password           String
  roles              MemberRole[]  @default([MEMBER])
  partId             String?
  isActive           Boolean       @default(true)
  sortOrder          Int           @default(0)
  accountStatus      AccountStatus @default(PENDING)
  mustChangePassword Boolean       @default(true)

  part             Part?            @relation(fields: [partId], references: [id])
  weeklyReports    WeeklyReport[]
  teamMemberships  TeamMembership[]
  teamJoinRequests TeamJoinRequest[]
  requestedTeams   Team[]           @relation("TeamRequester")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("members")
}

enum MemberRole {
  ADMIN
  LEADER
  PART_LEADER
  MEMBER
}

enum AccountStatus {
  PENDING
  APPROVED
  ACTIVE
  INACTIVE
}

enum TeamStatus {
  PENDING
  APPROVED
  ACTIVE
  INACTIVE
}

// ──────────── 팀 멤버십 ────────────

model TeamMembership {
  id        String       @id @default(cuid())
  memberId  String
  teamId    String
  partId    String?
  roles     MemberRole[] @default([MEMBER])
  sortOrder Int          @default(0)

  member Member @relation(fields: [memberId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])
  part   Part?  @relation(fields: [partId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, teamId])
  @@index([memberId])
  @@index([teamId])
  @@map("team_memberships")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TeamJoinRequest {
  id       String            @id @default(cuid())
  memberId String
  teamId   String
  status   JoinRequestStatus @default(PENDING)

  member Member @relation(fields: [memberId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([teamId])
  @@map("team_join_requests")
}

// ──────────── 프로젝트 ────────────

model Project {
  id        String          @id @default(cuid())
  name      String
  code      String          @unique
  category  ProjectCategory
  status    ProjectStatus   @default(ACTIVE)
  sortOrder Int             @default(0)

  teamProjects     TeamProject[]
  workItems        WorkItem[]
  summaryWorkItems SummaryWorkItem[]

  @@map("projects")
}

model TeamProject {
  id        String   @id @default(cuid())
  teamId    String
  projectId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  team    Team    @relation(fields: [teamId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([teamId, projectId])
  @@map("team_projects")
}

enum ProjectCategory {
  COMMON
  EXECUTION
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}

// ──────────── 주간업무 ────────────

model WeeklyReport {
  id        String       @id @default(cuid())
  memberId  String
  weekStart DateTime
  weekLabel String
  status    ReportStatus @default(DRAFT)

  member    Member     @relation(fields: [memberId], references: [id])
  workItems WorkItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, weekStart])
  @@index([weekStart])
  @@map("weekly_reports")
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

model WorkItem {
  id             String @id @default(cuid())
  weeklyReportId String
  projectId      String?

  doneWork  String  @db.Text
  planWork  String  @db.Text
  remarks   String? @db.Text
  sortOrder Int     @default(0)

  weeklyReport WeeklyReport @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weeklyReportId])
  @@index([projectId])
  @@map("work_items")
}

// ──────────── 파트/팀 취합보고 ────────────

enum SummaryScope {
  PART
  TEAM
}

model PartSummary {
  id        String       @id @default(cuid())
  partId    String?
  teamId    String?
  scope     SummaryScope @default(PART)
  weekStart DateTime
  weekLabel String
  title     String?
  status    ReportStatus @default(DRAFT)

  part             Part?             @relation(fields: [partId], references: [id])
  team             Team?             @relation(fields: [teamId], references: [id])
  summaryWorkItems SummaryWorkItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partId, weekStart])
  @@index([weekStart])
  @@map("part_summaries")
}

model SummaryWorkItem {
  id            String @id @default(cuid())
  partSummaryId String
  projectId     String

  doneWork    String  @db.Text
  planWork    String  @db.Text
  remarks     String? @db.Text
  memberNames String? @db.Text
  sortOrder   Int     @default(0)

  partSummary PartSummary @relation(fields: [partSummaryId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id])

  @@index([partSummaryId])
  @@map("summary_work_items")
}
