generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────── 조직 ────────────

model Team {
  id            String     @id @default(cuid())
  name          String     @unique
  description   String?
  teamStatus    TeamStatus @default(PENDING)
  requestedById String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  requestedBy      Member?            @relation("TeamRequester", fields: [requestedById], references: [id])
  parts            Part[]
  teamProjects     TeamProject[]
  partSummaries    PartSummary[]
  teamMemberships  TeamMembership[]
  teamJoinRequests TeamJoinRequest[]
  timesheets       MonthlyTimesheet[]

  @@map("teams")
}

model Part {
  id        String @id @default(cuid())
  name      String
  teamId    String
  sortOrder Int    @default(0)

  team            Team             @relation(fields: [teamId], references: [id])
  partSummaries   PartSummary[]
  teamMemberships TeamMembership[]

  @@unique([teamId, name])
  @@index([teamId, sortOrder])
  @@map("parts")
}

model Member {
  id                 String        @id @default(cuid())
  name               String
  email              String        @unique
  password           String
  roles              MemberRole[]  @default([MEMBER])
  isActive           Boolean       @default(true)
  sortOrder          Int           @default(0)
  accountStatus      AccountStatus @default(PENDING)
  mustChangePassword Boolean       @default(true)
  position           Position?
  jobTitle           String?

  weeklyReports        WeeklyReport[]
  teamMemberships      TeamMembership[]
  teamJoinRequests     TeamJoinRequest[]
  requestedTeams       Team[]               @relation("TeamRequester")
  timesheets           MonthlyTimesheet[]
  managedProjects      Project[]            @relation("ProjectManager")
  timesheetApprovals   TimesheetApproval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("members")
}

enum MemberRole {
  ADMIN
  LEADER
  PART_LEADER
  MEMBER
}

enum AccountStatus {
  PENDING
  APPROVED
  ACTIVE
  INACTIVE
}

enum TeamStatus {
  PENDING
  APPROVED
  ACTIVE
  INACTIVE
}

enum Position {
  DIRECTOR
  GENERAL_MANAGER
  DEPUTY_MANAGER
  ASSISTANT_MANAGER
  STAFF
  PRINCIPAL_RESEARCHER
  SENIOR_RESEARCHER
  RESEARCHER
  ASSOCIATE_RESEARCHER
}

// ──────────── 팀 멤버십 ────────────

model TeamMembership {
  id        String       @id @default(cuid())
  memberId  String
  teamId    String
  partId    String?
  roles     MemberRole[] @default([MEMBER])
  sortOrder Int          @default(0)

  member Member @relation(fields: [memberId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])
  part   Part?  @relation(fields: [partId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, teamId])
  @@index([memberId])
  @@index([teamId])
  @@map("team_memberships")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TeamJoinRequest {
  id       String            @id @default(cuid())
  memberId String
  teamId   String
  status   JoinRequestStatus @default(PENDING)

  member Member @relation(fields: [memberId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([teamId])
  @@index([memberId, teamId, status])
  @@map("team_join_requests")
}

// ──────────── 프로젝트 ────────────

model Project {
  id          String          @id @default(cuid())
  name        String
  code        String          @unique
  category    ProjectCategory
  status      ProjectStatus   @default(ACTIVE)
  sortOrder   Int             @default(0)
  managerId   String?
  department  String?
  description String?

  manager           Member?           @relation("ProjectManager", fields: [managerId], references: [id])
  teamProjects      TeamProject[]
  workItems         WorkItem[]
  summaryWorkItems  SummaryWorkItem[]
  timesheetWorkLogs TimesheetWorkLog[]

  @@index([status])
  @@map("projects")
}

model TeamProject {
  id        String   @id @default(cuid())
  teamId    String
  projectId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  team    Team    @relation(fields: [teamId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([teamId, projectId])
  @@map("team_projects")
}

enum ProjectCategory {
  COMMON
  EXECUTION
}

enum ProjectStatus {
  PENDING
  ACTIVE
  INACTIVE
}

// ──────────── 주간업무 ────────────

model WeeklyReport {
  id        String       @id @default(cuid())
  memberId  String
  weekStart DateTime
  weekLabel String
  status    ReportStatus @default(DRAFT)

  member    Member     @relation(fields: [memberId], references: [id])
  workItems WorkItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, weekStart])
  @@index([weekStart])
  @@map("weekly_reports")
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

model WorkItem {
  id             String @id @default(cuid())
  weeklyReportId String
  projectId      String?

  doneWork  String  @db.Text
  planWork  String  @db.Text
  remarks   String? @db.Text
  sortOrder Int     @default(0)

  weeklyReport WeeklyReport @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weeklyReportId])
  @@index([projectId])
  @@map("work_items")
}

// ──────────── 파트/팀 취합보고 ────────────

enum SummaryScope {
  PART
  TEAM
}

model PartSummary {
  id        String       @id @default(cuid())
  partId    String?
  teamId    String?
  scope     SummaryScope @default(PART)
  weekStart DateTime
  weekLabel String
  title     String?
  status    ReportStatus @default(DRAFT)

  part             Part?             @relation(fields: [partId], references: [id])
  team             Team?             @relation(fields: [teamId], references: [id])
  summaryWorkItems SummaryWorkItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partId, weekStart])
  @@index([weekStart])
  @@index([teamId, weekStart])
  @@map("part_summaries")
}

model SummaryWorkItem {
  id            String @id @default(cuid())
  partSummaryId String
  projectId     String

  doneWork    String  @db.Text
  planWork    String  @db.Text
  remarks     String? @db.Text
  memberNames String? @db.Text
  sortOrder   Int     @default(0)

  partSummary PartSummary @relation(fields: [partSummaryId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id])

  @@index([partSummaryId])
  @@map("summary_work_items")
}

// ──────────── 근무시간표 ────────────

enum AttendanceType {
  WORK
  HOLIDAY_WORK
  ANNUAL_LEAVE
  HALF_DAY_LEAVE
  HOLIDAY
}

enum WorkType {
  OFFICE
  FIELD
  REMOTE
  BUSINESS_TRIP
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ApprovalType {
  LEADER
  PROJECT_MANAGER
  ADMIN
}

model MonthlyTimesheet {
  id          String          @id @default(cuid())
  memberId    String
  teamId      String
  yearMonth   String
  status      TimesheetStatus @default(DRAFT)
  submittedAt DateTime?

  member    Member             @relation(fields: [memberId], references: [id])
  team      Team               @relation(fields: [teamId], references: [id])
  entries   TimesheetEntry[]
  approvals TimesheetApproval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, teamId, yearMonth])
  @@index([yearMonth])
  @@index([teamId])
  @@index([memberId])
  @@map("monthly_timesheets")
}

model TimesheetEntry {
  id          String         @id @default(cuid())
  timesheetId String
  date        DateTime       @db.Date
  attendance  AttendanceType @default(WORK)

  timesheet MonthlyTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  workLogs  TimesheetWorkLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([timesheetId, date])
  @@index([timesheetId])
  @@map("timesheet_entries")
}

model TimesheetWorkLog {
  id        String   @id @default(cuid())
  entryId   String
  projectId String
  hours     Float
  workType  WorkType

  entry   TimesheetEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  project Project        @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entryId])
  @@index([projectId])
  @@map("timesheet_work_logs")
}

model TimesheetApproval {
  id           String          @id @default(cuid())
  timesheetId  String
  approverId   String
  approvalType ApprovalType
  status       TimesheetStatus @default(DRAFT)
  comment      String?
  approvedAt   DateTime?
  autoApproved Boolean         @default(false)

  timesheet MonthlyTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  approver  Member           @relation(fields: [approverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([timesheetId, approvalType])
  @@index([approverId, approvalType])
  @@map("timesheet_approvals")
}
